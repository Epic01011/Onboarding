# ================================================
# Supabase — REQUIS pour l'authentification
# ================================================

# URL du projet Supabase
# Utiliser le préfixe VITE_ (recommandé pour ce projet Vite)
# OU NEXT_PUBLIC_ si vous avez déjà configuré Vercel avec ce préfixe.
# Les deux préfixes sont supportés (voir vite.config.ts → envPrefix).
VITE_SUPABASE_URL=https://rjdvmfakljgltsdoceqb.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://rjdvmfakljgltsdoceqb.supabase.co

# Publishable Key (anciennement Anon Key)
# Trouver dans : Supabase Dashboard → Connect → API Keys
# Format nouveau  : sb_publishable_xxxx  (supabase-js >= 2.x)
# Format classique : eyJhbGci...          (JWT HS256)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJqZHZtZmFrbGpnbHRzZG9jZXFiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4NjkxODgsImV4cCI6MjA4NzQ0NTE4OH0.grY3VMogkFZ-prdZ4vB_HBJDUI9mpMTsgu6Z1WrzVbk
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJqZHZtZmFrbGpnbHRzZG9jZXFiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4NjkxODgsImV4cCI6MjA4NzQ0NTE4OH0.grY3VMogkFZ-prdZ4vB_HBJDUI9mpMTsgu6Z1WrzVbk

# ================================================
# Supabase — Service Role Key (backend interne uniquement)
# ================================================

# ATTENTION : à ne JAMAIS exposer publiquement.
# Usage strictement interne au cabinet (backendApi.ts, table kv_store_f54b77bb).
# En production Vercel, configurer cette variable côté serveur uniquement.
# Trouver dans : Supabase Dashboard → Connect → API Keys → service_role
# IMPORTANT : variable serveur uniquement, sans prefixe VITE_
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ================================================
# Supabase Auth Providers (OAuth)
# ================================================

# GitHub OAuth (Supabase Dashboard → Auth → Providers → GitHub)
# Créer une GitHub OAuth App : https://github.com/settings/developers
AUTH_GITHUB_CLIENT_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Microsoft Azure / Microsoft 365 (Supabase Dashboard → Auth → Providers → Azure)
# Créer une App Registration : https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
AUTH_AZURE_CLIENT_ID=your_azure_client_id
AUTH_AZURE_SECRET=your_azure_client_secret

# ================================================
# Email (Vercel serverless /api/send-email)
# ================================================

# SendGrid (recommandé)
# Trouver dans : SendGrid Dashboard → Settings → API Keys
SENDGRID_API_KEY=SG.your_key_here
FROM_EMAIL=onboarding@cabinet.fr
FROM_NAME=CabinetFlow

# ================================================
# JeSignExpert — REQUIS pour la signature électronique
# ================================================

# Clé API JeSignExpert
VITE_JESIGNEXPERT_API_KEY=your_api_key_here

# Workspace ID JeSignExpert
VITE_JESIGNEXPERT_WORKSPACE_ID=your_workspace_id_here

# URL de base de l'API (optionnel)
VITE_JESIGNEXPERT_API_URL=https://api.jesignexpert.com/v1

# ================================================
# App (optionnel)
# ================================================
VITE_DEBUG_MODE=false
VITE_LOG_SIGNATURE_EVENTS=true

# ================================================
# Email — Fallback SendGrid (optionnel, remplacé par la config UI)
# ================================================
# Utilisé comme fallback si aucun service email n'est configuré dans l'UI
# (Configuration → Envoi d'emails → Google Gmail ou SendGrid)
# VITE_SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_FROM_EMAIL=votre-email@cabinet.fr
# VITE_FROM_NAME=Cabinet Expert-Comptable

# ================================================
# NE JAMAIS COMMITTER CES CLÉS EN PRODUCTION :
# - service_role JWT  → réserver au backend serveur uniquement
# - sb_secret_*       → réserver au backend serveur uniquement
# - SENDGRID_API_KEY  → variable Vercel (pas VITE_), jamais exposée au navigateur
# ================================================
